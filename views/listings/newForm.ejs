<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <form method="POST" action="/listings">
        <label for="NewTitle">
            title :
        </label>
        <input type="text" name="listing[title]" placeholder="Enter your title">
<br>
        <label for="NewDescription">
            description :
        </label>
        <input type="text" name="listing[description]" placeholder="Enter your description">
<br>
        <label for="NewImage">
            image :
        </label>
        <input type="text" name="listing[image]" placeholder="Enter image URL/link">
<br>
        <label for="NewPrice">
            Price :
        </label>
        <input type="number" name="listing[price]" placeholder="Enter your price">
<br>
        <label for="NewLocation">
            Location :
        </label>
        <input type="text" name="listing[location]" placeholder="Enter your Location">
<br>
        <label for="NewCountry">
            country :
        </label>
        <input type="text" name="listing[country]" placeholder="Enter your Country">
<br>
        <button>Submit</button>
    </form>
</body>
</html>