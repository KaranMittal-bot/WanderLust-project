<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <form method="POST" action="/listings">
        <div>
            <label for="NewTitle" class="form-label">
                title :
            </label>
            <input type="text" name="listing[title]" placeholder="Enter your title" class="form-control">
        </div>
<br>
        <div>
            <label for="NewDescription" class="form-label">
                description :
            </label>
            <input type="text" name="listing[description]" placeholder="Enter your description" class="form-control">
        </div>
        
<br>
        <div>
            <label for="NewImage" class="form-label">
                image :
            </label>
            <input type="text" name="listing[image]" placeholder="Enter image URL/link" class="form-control">
        </div>
<br>
        <div>
            <label for="NewPrice" class="form-label">
                Price :
            </label>
            <input type="number" name="listing[price]" placeholder="Enter your price" class="form-control">
        </div>
        
<br>
        <div>
            <label for="NewLocation" class="form-label">
                Location :
            </label>
            <input type="text" name="listing[location]" placeholder="Enter your Location" class="form-control">
        </div>
<br>
        <div>
            <label for="NewCountry" class="form-label">
                country :
            </label>
            <input type="text" name="listing[country]" placeholder="Enter your Country">
        </div>
<br>
        <button>Submit</button>
    </form>
</body>
</html>