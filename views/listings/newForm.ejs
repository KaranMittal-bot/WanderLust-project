<% layout("/layouts/boilerplate") %>
<br><br>
<div class="row">
    <div class="col-8 offset-2">
        <h3>
            Create New Listing
        </h3>
    <br>
        <form method="POST" action="/listings">
            <div>
                <label for="NewTitle" class="form-label">
                    title :
                </label>
                <input type="text" name="listing[title]" placeholder="Add a catchy title" class="form-control">
            </div>
    <br>
            <div>
                <label for="NewDescription" class="form-label">
                    description :
                </label>
                <textarea name="listing[description]" placeholder="Describe your atmosphere" class="form-control"></textarea>
            </div>
            
    <br>
            <div>
                <label for="NewImage" class="form-label">
                    image :
                </label>
                <input type="text" name="listing[image]" placeholder="Enter image URL/link" class="form-control">
            </div>
    <br>
            <div>
                <label for="NewPrice" class="form-label">
                    Price :
                </label>
                <input type="number" name="listing[price]" placeholder="₹1500" class="form-control">
            </div>
            
    <br>
            <div>
                <label for="NewLocation" class="form-label">
                    Location :
                </label>
                <input type="text" name="listing[location]" placeholder="Dehradun, Uttrakhand" class="form-control">
            </div>
    <br>
            <div>
                <label for="NewCountry" class="form-label">
                    country :
                </label>
                <input type="text" name="listing[country]" placeholder="India" class="form-control">
            </div>
    <br>
            <button class="btn btn-dark add-btn">Submit</button>
            <br><br>
        </form>
    </div>
</div>


<!--! provided new boot classes to newForm.ejs for styling -->