<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3>
        edit :
    </h3>

    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <label for="NewTitle">
            title :
        </label>
        <input type="text" name="listing[title]" value="<%=listing.title %>">
<br>
        <label for="NewDescription">
            description :
        </label>
        <input type="text" name="listing[description]" value=" <%= listing.description %>">
<br>
        <label for="NewImage">
            image :
        </label>
        <input type="text" name="listing[image][url]" value="<%=listing.image.url%>">
<br>
        <label for="NewPrice">
            Price :
        </label>
        <input type="number" name="listing[price]" value="<%=listing.price %>">
<br>
        <label for="NewLocation">
            Location :
        </label>
        <input type="text" name="listing[location]" value="<%=listing.location%>">
<br>
        <label for="NewCountry">
            country :
        </label>
        <input type="text" name="listing[country]" value="<%=listing.country %>">
<br>
        <button>Submit</button>
    </form>
</body>
</html>